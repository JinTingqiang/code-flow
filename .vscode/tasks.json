{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "command": "npx tsc -p ./",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$tsc",
      "label": "tsc: compile",
      "options": {
        "shell": {
          "executable": "cmd.exe",
          "args": ["/d", "/c"]
        }
      }
    },
    {
      "type": "shell",
      "command": "npx tsc -watch -p ./",
      "group": "build",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "label": "tsc: watch",
      "options": {
        "shell": {
          "executable": "cmd.exe",
          "args": ["/d", "/c"]
        }
      }
    }
  ]
}
